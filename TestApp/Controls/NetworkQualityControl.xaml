<UserControl x:Class="TestApp.Controls.NetworkQualityControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TestApp.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="QualityButtonStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Border"
                                BorderBrush="#CCCCCC"
                                BorderThickness="1"
                                Background="Transparent"
                                CornerRadius="6"
                                Padding="12,8"
                                Cursor="Hand">
                            <StackPanel HorizontalAlignment="Center">
                                <ContentPresenter Margin="0,0,0,6"/>
                                <TextBlock x:Name="Label"
                                           Text="{TemplateBinding Tag}"
                                           FontSize="11"
                                           Foreground="#888"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#378ADD"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="Border" Property="Background" Value="#E6F1FB"/>
                                <Setter TargetName="Label" Property="Foreground" Value="#185FA5"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#AAAAAA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel Orientation="Horizontal">

        <RadioButton Style="{StaticResource QualityButtonStyle}"
                     x:Name="LowRB"
                     GroupName="Quality" Checked="RadioButton_Checked" Tag="Низкое" Margin="0,0,8,0">
            <Canvas Width="22" Height="18">
                <Rectangle Canvas.Left="0"  Canvas.Bottom="0" Width="4" Height="6"  Fill="#E24B4A" RadiusX="1" RadiusY="1"/>
                <Rectangle Canvas.Left="6"  Canvas.Bottom="0" Width="4" Height="10" Fill="#CCCCCC" RadiusX="1" RadiusY="1"/>
                <Rectangle Canvas.Left="12" Canvas.Bottom="0" Width="4" Height="14" Fill="#CCCCCC" RadiusX="1" RadiusY="1"/>
                <Rectangle Canvas.Left="18" Canvas.Bottom="0" Width="4" Height="18" Fill="#CCCCCC" RadiusX="1" RadiusY="1"/>
            </Canvas>
        </RadioButton>

        <RadioButton Style="{StaticResource QualityButtonStyle}"
                     x:Name="MediumRB"
                     GroupName="Quality" Checked="RadioButton_Checked" Tag="Среднее" Margin="0,0,8,0">
            <Canvas Width="22" Height="18">
                <Rectangle Canvas.Left="0"  Canvas.Bottom="0" Width="4" Height="6"  Fill="#EF9F27" RadiusX="1" RadiusY="1"/>
                <Rectangle Canvas.Left="6"  Canvas.Bottom="0" Width="4" Height="10" Fill="#EF9F27" RadiusX="1" RadiusY="1"/>
                <Rectangle Canvas.Left="12" Canvas.Bottom="0" Width="4" Height="14" Fill="#CCCCCC" RadiusX="1" RadiusY="1"/>
                <Rectangle Canvas.Left="18" Canvas.Bottom="0" Width="4" Height="18" Fill="#CCCCCC" RadiusX="1" RadiusY="1"/>
            </Canvas>
        </RadioButton>

        <RadioButton Style="{StaticResource QualityButtonStyle}"
                     x:Name="HighRB"
                     GroupName="Quality" Checked="RadioButton_Checked" Tag="Высокое" IsChecked="True" Margin="0,0,8,0">
            <Canvas Width="22" Height="18">
                <Rectangle Canvas.Left="0"  Canvas.Bottom="0" Width="4" Height="6"  Fill="#1D9E75" RadiusX="1" RadiusY="1"/>
                <Rectangle Canvas.Left="6"  Canvas.Bottom="0" Width="4" Height="10" Fill="#1D9E75" RadiusX="1" RadiusY="1"/>
                <Rectangle Canvas.Left="12" Canvas.Bottom="0" Width="4" Height="14" Fill="#1D9E75" RadiusX="1" RadiusY="1"/>
                <Rectangle Canvas.Left="18" Canvas.Bottom="0" Width="4" Height="18" Fill="#CCCCCC" RadiusX="1" RadiusY="1"/>
            </Canvas>
        </RadioButton>

        <RadioButton Style="{StaticResource QualityButtonStyle}"
                     x:Name="ExcellentRB"
                     GroupName="Quality" Checked="RadioButton_Checked" Tag="Отличное">
            <Canvas Width="22" Height="18">
                <Rectangle Canvas.Left="0"  Canvas.Bottom="0" Width="4" Height="6"  Fill="#185FA5" RadiusX="1" RadiusY="1"/>
                <Rectangle Canvas.Left="6"  Canvas.Bottom="0" Width="4" Height="10" Fill="#185FA5" RadiusX="1" RadiusY="1"/>
                <Rectangle Canvas.Left="12" Canvas.Bottom="0" Width="4" Height="14" Fill="#185FA5" RadiusX="1" RadiusY="1"/>
                <Rectangle Canvas.Left="18" Canvas.Bottom="0" Width="4" Height="18" Fill="#185FA5" RadiusX="1" RadiusY="1"/>
            </Canvas>
        </RadioButton>

    </StackPanel>
</UserControl>
