<Window x:Class="TestApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TestApp"
        mc:Ignorable="d"
        xmlns:controls="clr-namespace:TestApp.Controls"
        xmlns:views="clr-namespace:TestApp.Views"
        Title="Загрузчик изображений" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Margin="10,10,0,0" Text="Качество интернета"/>
            <controls:NetworkQualityControl Quality="{Binding Quality, Mode=TwoWay}" Margin="10"/>
        </StackPanel>


        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <views:ImageSlotView 
                Margin="10"
                DataContext="{Binding Slot1}"
                Grid.Column="0"/>

            <views:ImageSlotView 
                Margin="10"
                DataContext="{Binding Slot2}"
                Grid.Column="1"/>

            <views:ImageSlotView 
                Margin="10"
                DataContext="{Binding Slot3}"
                Grid.Column="2"/>

            <Button 
                Command="{Binding StartAllCommand}"
                Margin="10"
                Content="Start All" 
                Grid.Row="1"
                Grid.ColumnSpan="3"/>
            <ProgressBar
                Margin="10,0,10,10"
                Grid.Row="2"
                Grid.ColumnSpan="3"
                Height="20"
                Maximum="3"
                Value="{Binding Progress, Mode=OneWay}"/>


        </Grid>
    </Grid>

</Window>
